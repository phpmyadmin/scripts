#!/bin/bash

# Script to install pre-built demo variants on the demo server
# Fetches tarballs from a build server over HTTP instead of building locally.
# Requires $HOME/scripts to be a checkout of the scripts repository

# Fail on undefined variables
set -u
# Fail on failure
set -e
# If a script fails, stop before the next pipe
set -o pipefail

FORCE_MODE="0"
QUIET_MODE="0"
LOG_FILE="/dev/null"
BUILD_URL=""

# Source: https://stackoverflow.com/a/31024664/5155484
while [[ $# -gt 0 ]]
do
    key="$1"
    while [[ ${key+x} ]]
    do
        case $key in
            --help)
                echo "  Options:"
                echo "    --build-url  URL or local folder path where built tarballs are served from"
                echo "    --force      Install even if there are no new changes"
                echo "    --log-file   Where to log the debug log, defaults to /dev/null (but logs are still printed to the screen)"
                echo "    -q           Quiet mode, no logs are printed to the screen"
                echo "    "
                echo "  You can define the following ENV variables:"
                echo "    WEB_STORAGE    Defaults to ~/.pma-demo-web"
                echo "    STATE_STORAGE  Defaults to ~/.pma-demo-state"
                echo "    WEB_GROUP      Defaults to www-data"
                exit 0
                ;;
            --build-url)
                BUILD_URL="$2"
                shift # option has parameter
                ;;
            --force)
                FORCE_MODE="1"
                ;;
            -q)
                QUIET_MODE="1"
                ;;
            --log-file)
                LOG_FILE="$2"
                shift # option has parameter
                ;;
            *)
                # unknown option
                echo "Unknown option: $key"
                echo "Use --help for the list of available options."
                exit 10
                ;;
        esac
        # prepare for next option in this key, if any
        [[ "$key" = -? || "$key" == --* ]] && unset key || key="${key/#-?/-}"
    done
    shift # option(s) fully processed, proceed to next input argument
done

if [ -z "$BUILD_URL" ] ; then
    echo "Missing required argument: --build-url <url>"
    exit 1
fi

# Strip trailing slash
BUILD_URL="${BUILD_URL%/}"

# Allow passing a local directory path instead of an URL
if [[ "$BUILD_URL" = /* ]] ; then
    if [ ! -d "$BUILD_URL" ] ; then
        echo "ERROR: $BUILD_URL is not a directory"
        exit 1
    fi
    BUILD_URL="file://$BUILD_URL"
fi

debugLog() {
    echo "$1" >> "$LOG_FILE"
    if [ "${QUIET_MODE}" = "1" ] ; then
        return
    fi
    echo "$1"
}

SCRIPTS_FOLDER="$(realpath "$(dirname "$(realpath "$0")")/../../")"

debugLog "Running in $SCRIPTS_FOLDER"

# Directory where web folders are installed
WEB_STORAGE="${WEB_STORAGE:-$HOME/.pma-demo-web}"
# The user group to own the installed files
WEB_GROUP="${WEB_GROUP:-www-data}"
# Directory where the last-installed commit hashes are tracked
STATE_STORAGE="${STATE_STORAGE:-$HOME/.pma-demo-state}"

mkdir -p "$STATE_STORAGE"
mkdir -p "$WEB_STORAGE"

debugLog "Sync config-common.inc.php into $WEB_STORAGE"
cp "$SCRIPTS_FOLDER/demo/php/config-common.inc.php" "$WEB_STORAGE/config-common.inc.php"

# Read variants from versions.ini
VARIANTS=$(awk '/^variants/ {print $3}' "$SCRIPTS_FOLDER/demo/php/versions.ini")

for VARIANT_DATA in $VARIANTS ; do
    VARIANT_NAME="${VARIANT_DATA%%:*}"
    VARIANT_BRANCH="${VARIANT_DATA##*:}"
    if [ -z "$VARIANT_NAME" ] || [ -z "$VARIANT_BRANCH" ] ; then
        debugLog "Invalid variant data: $VARIANT_DATA"
        continue
    fi

    STATE_FILE="$STATE_STORAGE/demo-$VARIANT_NAME.txt"
    STATE_FILE_TMP="$STATE_FILE.tmp"
    REMOTE_STATE_URL="$BUILD_URL/demo-$VARIANT_NAME.txt"

    debugLog "Fetching commit from $REMOTE_STATE_URL"
    if ! curl -sf -o "$STATE_FILE_TMP" "$REMOTE_STATE_URL" ; then
        debugLog "ERROR: could not fetch $REMOTE_STATE_URL"
        continue
    fi
    REMOTE_COMMIT="$(grep -F "commit" "$STATE_FILE_TMP" | cut -f 2)"

    if [ -z "$REMOTE_COMMIT" ] ; then
        debugLog "ERROR: no commit found in $REMOTE_STATE_URL"
        rm "$STATE_FILE_TMP"
        continue
    fi

    # Skip if already at this commit
    if [ -f "$STATE_FILE" ] && [ "$FORCE_MODE" = "0" ] ; then
        LOCAL_COMMIT="$(grep -F "commit" "$STATE_FILE" | cut -f 2)"
        if [ "$REMOTE_COMMIT" = "$LOCAL_COMMIT" ] ; then
            debugLog "Skipping $VARIANT_NAME: already at $REMOTE_COMMIT"
            rm "$STATE_FILE_TMP"
            continue
        fi
    fi

    debugLog "Installing $VARIANT_NAME at $REMOTE_COMMIT"

    TARBALL_URL="$BUILD_URL/$VARIANT_NAME.tar.gz"

    WEB_FOLDER="$WEB_STORAGE/$VARIANT_NAME"
    if [ -d "$WEB_FOLDER" ] ; then
        debugLog "Cleaning up $WEB_FOLDER"
        rm -r "$WEB_FOLDER"
    fi

    debugLog "Creating $WEB_FOLDER"
    mkdir "$WEB_FOLDER"
    chgrp "$WEB_GROUP" "$WEB_FOLDER"

    debugLog "Downloading and extracting $TARBALL_URL into $WEB_FOLDER"
    if ! curl -sf "$TARBALL_URL" | tar -xz --strip-components=1 --directory="$WEB_FOLDER" ; then
        debugLog "ERROR: could not download or extract $TARBALL_URL"
        if [ -d "$WEB_FOLDER" ] ; then
            rm -r "$WEB_FOLDER"
        fi
        rm "$STATE_FILE_TMP"
        continue
    fi

    # Copy configuration files
    FLAVOUR="${VARIANT_NAME#*-}"
    debugLog "Copying config for flavour: $FLAVOUR"
    if [ -f "$SCRIPTS_FOLDER/demo/php/config-$FLAVOUR.inc.php" ] ; then
        cp "$SCRIPTS_FOLDER/demo/php/config-$FLAVOUR.inc.php" "$WEB_FOLDER/config.inc.php"
    else
        cp "$SCRIPTS_FOLDER/demo/php/config.inc.php" "$WEB_FOLDER/config.inc.php"
    fi
    cp "$SCRIPTS_FOLDER/demo/php/"config.*.inc.php "$WEB_FOLDER/"

    sed -i "s,%CONF_PATH%,$WEB_STORAGE,g" "$WEB_FOLDER/config.inc.php"

    debugLog "Changing group owner"
    # Apply permissions
    chgrp -R "$WEB_GROUP" "$WEB_FOLDER"

    # Apply permissions to files and folders
    debugLog "Changing permissions"
    # X applies execute/traverse only to directories,
    # so files get 0644 and directories get 0755.
    chmod -R "u=rwX,g=rX,o=rX" "$WEB_FOLDER"

    debugLog "Making a temp directory"
    # Create writable tmp dir
    mkdir -p "$WEB_FOLDER/tmp/"
    chmod 770 "$WEB_FOLDER/tmp/"
    chgrp "$WEB_GROUP" "$WEB_FOLDER/tmp/"

    # Atomically record the new state only once everything succeeded
    mv "$STATE_FILE_TMP" "$STATE_FILE"

    debugLog "Installed $VARIANT_NAME"
done

debugLog "Deleting stale directories"

find "$WEB_STORAGE" -maxdepth 1 -mindepth 1 -type d | while read -r DIRNAME ; do
    FOLDER_NAME="${DIRNAME##*/}"

    for VARIANT_DATA in $VARIANTS ; do
        VARIANT_NAME="${VARIANT_DATA%%:*}"
        if [ "$FOLDER_NAME" = "$VARIANT_NAME" ] ; then
            debugLog "Known variant: $FOLDER_NAME"
            continue 2
        fi
    done

    debugLog "Deleting stale variant $FOLDER_NAME"
    if [ -d "$DIRNAME" ] ; then
        rm -r "$DIRNAME"
    fi
done

debugLog "All done"
